{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KPI Validation Spec",
  "description": "Deterministic validation plan for an old-vs-new KPI reconciliation.",
  "type": "object",
  "required": ["metric", "grain", "checks"],
  "properties": {
    "metric": {
      "type": "string",
      "description": "Metric name, e.g. 'monthly_net_revenue'."
    },
    "grain": {
      "type": "array",
      "description": "Columns that define one row of the metric, e.g. ['cohort_month'].",
      "items": { "type": "string" },
      "minItems": 1
    },
    "measures": {
      "type": "array",
      "description": "Numeric columns being reconciled.",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "description": "Deterministic checks to run.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["row_count", "sum_tolerance", "key_overlap", "per_dimension_tolerance", "null_rate"]
          },
          "column": { "type": "string", "description": "Measure or dimension the check applies to." },
          "tolerance_abs": { "type": "number", "description": "Absolute tolerance." },
          "tolerance_pct": { "type": "number", "description": "Relative tolerance as a fraction, e.g. 0.005 = 0.5%." },
          "dimension": { "type": "string", "description": "Dimension for per_dimension_tolerance." },
          "max_null_rate": { "type": "number", "description": "Max allowed null fraction for null_rate." }
        }
      }
    }
  }
}
